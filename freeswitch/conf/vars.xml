<?xml version="1.0" encoding="UTF-8"?>
<include>
  <X-PRE-PROCESS cmd="set" data="local_ip_v4=auto"/>
  <X-PRE-PROCESS cmd="set" data="local_ip=$${local_ip_v4}"/>
  <X-PRE-PROCESS cmd="set" data="external_rtp_ip=$${local_ip}"/>
  <X-PRE-PROCESS cmd="set" data="external_sip_ip=$${local_ip}"/>
  <!-- ip-watcher sobrescreve external_sip_ip e external_rtp_ip com o IP público real -->
  <X-PRE-PROCESS cmd="include" data="/etc/freeswitch/vars-external-ip.xml"/>

  <X-PRE-PROCESS cmd="set" data="domain=zenith.local"/>
  <X-PRE-PROCESS cmd="set" data="pbx_host=sip.maisalerta.tecnorise.com"/>

  <!-- Tenant Akom (primeiro cliente real, feature Fase 1 — registro+gravação).
       Ramais registrados nativamente no FreeSWITCH (não via bypass_to_pbx da
       VitalPBX) usam esses valores fixos, provisionados via
       scripts/provision_tenant.py. Sem isso, esl_client.py não cria a linha
       Call (guard "if tenant_id:") e a gravação fica órfã. -->
  <X-PRE-PROCESS cmd="set" data="tenant_id=akom"/>
  <X-PRE-PROCESS cmd="set" data="pbx_id=0cc6c169-c319-4a3f-8daf-ad8412737d68"/>

  <!-- FreeSWITCH roda em network_mode: host (não resolve nomes de container
       Docker como "zenith-api-1" via DNS interno). zenith_api_host aponta
       para a porta publicada no host (feature 007-audio-stream-migration). -->
  <X-PRE-PROCESS cmd="set" data="zenith_api_host=127.0.0.1:8001"/>

  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=OPUS,G722,PCMU,PCMA,G729,H264,VP8"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=OPUS,G722,PCMU,PCMA,G729,H264,VP8"/>

  <X-PRE-PROCESS cmd="set" data="sound_prefix=/usr/share/freeswitch/sounds/en/us/callie"/>
</include>
