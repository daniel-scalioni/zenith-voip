<?xml version="1.0" encoding="UTF-8"?>
<include>
  <domain name="$${domain}">
    <params>
      <param name="dial-string" value="{^^:sip_invite_domain=${dialed_domain}:presence_id=${dialed_user}@${dialed_domain}}${sofia_contact(*/${dialed_user}@${dialed_domain})}"/>
    </params>
    <!-- Placeholder: nenhum usuário/extensão real ainda. Diretório dinâmico de ramais (mod_xml_curl + SIPExtension) entra num ciclo futuro. -->
    <groups>
      <group name="default">
        <users>
          <!-- Gerado por scripts/import_extensions.py (extensions.xml é gitignored — contém senhas) -->
          <X-PRE-PROCESS cmd="include" data="extensions.xml"/>
        </users>
      </group>
    </groups>
  </domain>
</include>
