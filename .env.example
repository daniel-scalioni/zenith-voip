# -------------------------------------------------------
# Exemplo de configuração — copie para .env e ajuste
# -------------------------------------------------------

# ip-watcher (sidecar de detecção dinâmica de IP externo)
# -------------------------------------------------------
# URL do endpoint HTTP/HTTPS que retorna o IP público do CPD (texto puro, ex.: "200.170.149.139")
# Pode ser um serviço público (api.ipify.org, ifconfig.me) ou endpoint próprio
EXTERNAL_IP_ENDPOINT=https://api.ipify.org

# Senha ESL do FreeSWITCH — deve coincidir com event_socket.conf.xml
FREESWITCH_ESL_PASSWORD=ClueCon

# Intervalo de polling em segundos (default 60)
POLL_INTERVAL=60

# Somente dev: quando definido, bypassa o endpoint HTTP e usa este IP fixo
# MOCK_EXTERNAL_IP=189.112.222.244
